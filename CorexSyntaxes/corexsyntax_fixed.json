      "match": "\\b(continueLoop|breakLoop|exitLoop|returnValue|throwError|tryFinally|catchException|repeatUntil|foreachIn|selectCase|defaultCase|whenMatched|otherwiseMatched|waitEvent|signalEvent|emitEvent|broadcastEvent|onTrigger|offTrigger|subscribeEvent|unsubscribeEvent|triggerEvent|handleCallback|invokeListener|registerListener|deregisterListener|scheduleTask|enqueueTask|dequeueTask|spawnProcess|killProcess|startRoutine|stopRoutine|pauseRoutine|resumeRoutine|initialize|finalize|cleanup|resetState|updateState|loadModule|unloadModule|importModule|exportModule)\\b"
