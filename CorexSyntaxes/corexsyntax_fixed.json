      "match": "\\b(Boolean|Integer|Float|Double|Character|String|Array|Map|Dictionary|Set|List|Tuple|Void|Any|Number|Date|Time|Buffer|Regex|Lambda|Function|Coroutine|Thread|Process|Event|Signal|Task|Module|Package|Struct|Enum|Interface|Object|Class)\\b"
